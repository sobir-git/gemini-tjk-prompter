GEMINI_API_KEY=your_gemini_api_key_here
CORS_ORIGIN=https://your-frontend-domain.railway.app

# Telemetry authentication (optional - if not set, telemetry endpoint is disabled)
TELEMETRY_USER=your_telemetry_username
TELEMETRY_PASSWORD=your_secure_password_here

# Set to "true" only when deployed behind a trusted reverse proxy (e.g. Railway, nginx).
# When true, the real client IP is read from X-Forwarded-For for per-IP rate limiting.
# Leave unset or "false" when running directly (RemoteAddr is used instead).
TRUSTED_PROXY=false
